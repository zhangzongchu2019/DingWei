# WorkPulse bootstrap template.
# Copy this file to `.env`, fill real values, then `chmod 600 .env`.
# `.env` is gitignored; never commit real passwords, app_secret, API keys, domains, or tokens.

# -----------------------------------------------------------------------------
# Required bootstrap
# -----------------------------------------------------------------------------

# REQUIRED. AES-GCM key material for encrypting bot app_secret and other sensitive
# DB values. Generate with:
#   openssl rand -hex 32
# Back this up together with data/workpulse.db. If lost, encrypted secrets in the
# DB cannot be decrypted.
WP_SECRET_KEY=

# SQLite main DB and data directory. Keep both on persistent storage.
WP_DB_PATH=./data/workpulse.db
WP_DATA_DIR=./data

# HTTP listen address. For systemd + nginx, listen on localhost only.
WP_ADDR=127.0.0.1:8791

# Initial admin seed. Used only when the DB has no admin user yet.
WP_ADMIN_USER=admin
WP_ADMIN_INIT_PASSWORD=

# Optional global schedule export path used by legacy/portal integrations.
WP_GLOBAL_SCHEDULE_PATH=./data/global-schedule.json

# -----------------------------------------------------------------------------
# Feishu bootstrap bot
# -----------------------------------------------------------------------------

# Long connection is the production transport. `fake` is only for local tests.
FEISHU_TRANSPORT=ws

# Bootstrap first bot channel. After boot, more bots are managed from M9 backend.
FEISHU_BOT_CHANNEL_ID=unifiedrobot
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Only needed for callback-style integrations; long connection does not require
# them, but keep placeholders for compatibility.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# -----------------------------------------------------------------------------
# Scheduler / evidence coordinator (R8/R9)
# These bootstrap values can be overridden from M9 runtime config where available:
# schedule.notify_chat, schedule.notify_bot, schedule.transcript_dirs,
# schedule.evidence_cron, schedule.evidence_tz.
# -----------------------------------------------------------------------------

# System-level CLI used by scheduler coordination/evidence jobs, for example:
#   <your-ai-cli> --print
# Configure deepseek-cli credentials outside git. Use an absolute path in
# production; systemd EnvironmentFile does not expand "~".
WP_SCHEDULER_CLI=
WP_SCHEDULER_CONFIG_DIR=

# Baseline schedule files. Use absolute paths in production.
WP_SCHEDULE_TEAM_FILE=docs/AI研究任务排期/AI-研究工作内容清单.md
WP_SCHEDULE_PERSONAL_DIR=docs/AI研究任务排期
WP_SCHEDULE_BACKUP_DIR=./data/schedule-backup

# Feishu group chat and bot channel used for schedule/evidence summaries.
WP_SCHEDULE_NOTIFY_CHAT=
WP_SCHEDULE_NOTIFY_BOT=unifiedrobot

# Optional seed identifiers for a brand-new DB. Leave empty for public/local
# bootstrap, or set in the deployment environment when the real Feishu resources
# already exist. Do not commit real Feishu open_id/chat_id/app_id values.
WP_SEED_AGGREGATE_CHAT=
WP_SEED_CCCONNECTOR_APPID=

# Secret for the seeded SYSTEM-V-TASK-INTERNAL producer API key (system tasks that
# only post to groups). Empty → the seed key is marked unusable ("unusable-..."); set
# a strong random value in the deployment environment to enable it. Never commit.
WP_SYSTEM_V_TASK_SECRET=

# Optional #系统安全 admin allowlist by Feishu open_id. When empty, the security
# route still allows the owner_key-based admin gate (`zsf`) from DB bindings.
WP_SECOPS_ADMIN_OPENID=

# Evidence cron defaults to UTC 00:00 and 06:00. Change from M9 config if needed.
WP_SCHEDULE_EVIDENCE_CRON="0 0,6 * * *"
WP_SCHEDULE_EVIDENCE_TZ=UTC

# Additional transcript directories, comma-separated. WorkPulse also reads
# collected session messages from DB.
WP_TRANSCRIPT_DIRS=

# -----------------------------------------------------------------------------
# sessionHelper side notes (not read by workpulse server)
# -----------------------------------------------------------------------------

# SH_COLLECT belongs to tools/sessionhelper/run.sh local config. Default is 1:
# collect local AI CLI transcript rounds into WorkPulse for evidence, without
# sending them to Feishu. `collect.retain_days` is configured from M9 runtime
# config; default retention is defined by the server.
# SH_COLLECT=1
